# .env.example — Copia esto como .env.local para desarrollo
# Y añade estas variables en Vercel > Settings > Environment Variables

# Supabase — las encuentras en: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# IMPORTANTE:
# - SUPABASE_URL: Project URL (no la anon key URL)
# - SUPABASE_SERVICE_KEY: service_role key (NO la anon key)
#   La service_role key está en: Settings > API > Project API keys > service_role
#   NUNCA expongas esta key en el frontend — solo se usa en las API functions del servidor
